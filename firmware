void executeForwardStep() {
  showFaceSleepy();
  display.clearDisplay();
  display.drawBitmap(0, 0, epd_bitmap_walk, 128, 64, SSD1306_WHITE);
  display.display();

  // ======================================================================
  // STEP 1: Move BACK LEFT (BL) Leg Forward
  // ======================================================================
  setServoAngle(BL_KNEE, 110);                // Lift Knee High
  if (!pressingCheck("forward", aaDelay)) return;
  setServoAngle(BL_HIP, 140);                  // Swing Hip Forward (Calibrated Stroke)
  if (!pressingCheck("forward", aaDelay)) return;
  setServoAngle(BL_KNEE, safeBL_Knee);        // Plant Leg Down
  if (!pressingCheck("forward", aaDelay)) return;

  // ======================================================================
  // STEP 2: Move FRONT LEFT (FL) Leg Forward
  // ======================================================================
  setServoAngle(FL_KNEE, 140);                // Lift Knee High
  if (!pressingCheck("forward", aaDelay)) return;
  setServoAngle(FL_HIP, 155);                 // Swing Hip Forward (Calibrated Stroke)
  if (!pressingCheck("forward", aaDelay)) return;
  setServoAngle(FL_KNEE, safeFL_Knee);        // Plant Leg Down
  if (!pressingCheck("forward", aaDelay)) return;

 
  // ======================================================================
  // STEP 4: Move BACK RIGHT (BR) Leg Forward
  // ======================================================================
  setServoAngle(BR_KNEE, 80);                 // Lift Knee High (Inverse Axis)
  if (!pressingCheck("forward", aaDelay)) return;
  setServoAngle(BR_HIP, 45);                 // Swing Hip Forward (Calibrated Stroke)
  if (!pressingCheck("forward", aaDelay)) return;
  setServoAngle(BR_KNEE, safeBR_Knee);        // Plant Leg Down
  if (!pressingCheck("forward", aaDelay)) return;

   // ======================================================================
  // STEP 3: Move FRONT RIGHT (FR) Leg Forward
  // ======================================================================
  setServoAngle(FR_KNEE, 40);                 // Lift Knee High (Inverse Axis)
  if (!pressingCheck("forward", aaDelay)) return;
  setServoAngle(FR_HIP, 25);                  // Swing Hip Forward (Calibrated Stroke)
  if (!pressingCheck("forward", aaDelay)) return;
  setServoAngle(FR_KNEE, safeFR_Knee);        // Plant Leg Down
  if (!pressingCheck("forward", aaDelay)) return;

  // ======================================================================
  // STEP 5: COHESIVE UNIFIED BODY PROPULSION GLIDE
  // All 4 legs push backward together, gliding the main chassis forward
  // ======================================================================
  setServoAngle(FL_HIP, safeFL_Hip); 
  setServoAngle(BR_HIP, safeBR_Hip); 
  setServoAngle(FR_HIP, safeFR_Hip); 
  setServoAngle(BL_HIP, safeBL_Hip); 
  if (!pressingCheck("forward", aaDelay * 2)) return; // Stance recovery delay
}
// ====== FIXED RIGHT TURN GAIT LOOP ======

void executeRightTurnStep() {
  showFaceSleepy();
  display.clearDisplay();
  display.drawBitmap(0, 0, epd_bitmap_talk_thinking, 128, 64, SSD1306_WHITE);
  display.display();
  
  // ======================================================================
  // STEP 1: DIAGONAL PAIR A SWING (Front Left & Back Right)
  // ======================================================================
  // 1. Raise FL_Knee and BR_Knee up
  setServoAngle(FL_KNEE, 140);          // High clearance lift for FL
  setServoAngle(BR_KNEE, 140);           // High clearance lift for BR (Inverse axis)
  if (!pressingCheck("right", 150)) return;
  
  // 2. Turn FL_Hip and BR_Hip to 35 degrees
  setServoAngle(FL_HIP, 35);            
  setServoAngle(BR_HIP, 35);            
  if (!pressingCheck("right", 150)) return;
  
  // 3. Place FL_Knee and BR_Knee down to normal safe positions
  setServoAngle(FL_KNEE, safeFL_Knee); 
  setServoAngle(BR_KNEE, safeBR_Knee); 
  if (!pressingCheck("right", frameDelay)) return;

  // ======================================================================
  // STEP 2: DIAGONAL PAIR B SWING (Front Right & Back Left)
  // ======================================================================
  // 1. Raise FR_Knee and BL_Knee up
  setServoAngle(FR_KNEE, 40);           // High clearance lift for FR (Inverse axis)
  setServoAngle(BL_KNEE, 40);          // High clearance lift for BL
  if (!pressingCheck("right", 150)) return;
  
  // 2. Turn FR_Hip and BL_Hip to 35 degrees
  setServoAngle(FR_HIP, 35);            
  setServoAngle(BL_HIP, 35);            
  if (!pressingCheck("right", 150)) return;
  
  // 3. Keep the knees down again to normal
  setServoAngle(FR_KNEE, safeFR_Knee); 
  setServoAngle(BL_KNEE, safeBL_Knee); 
  if (!pressingCheck("right", frameDelay)) return;

  // ======================================================================
  // STEP 3: COHESIVE CENTER SHIFT / RECOVERY
  // Return all hips back to their safe center home configuration
  // ======================================================================
  setServoAngle(FL_HIP, safeFL_Hip);
  setServoAngle(BR_HIP, safeBR_Hip);
  setServoAngle(FR_HIP, safeFR_Hip);
  setServoAngle(BL_HIP, safeBL_Hip);
  if (!pressingCheck("right", frameDelay * 2)) return;
}


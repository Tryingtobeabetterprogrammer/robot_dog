// ======================================================================
// --- INTERRUPTIBLE SMART TIMING ENGINE ---
// ======================================================================
bool pressingCheck(String expectedCmd, int msToWait) {
  unsigned long start = millis();
  while (millis() - start < msToWait) {
    dnsServer.processNextRequest(); 
    server.handleClient();          
    if (currentCommand != expectedCmd) {
      return false; 
    }
    yield(); 
  }
  return true;
}
void handleBackgroundOLED() {
  // Check if 5 seconds have passed since the last background screen transition
  unsigned long currentTime = millis();
  if (currentTime - lastScreenChangeTime >= screenInterval) {
    lastScreenChangeTime = currentTime;
    currentScreenState = (currentScreenState + 1) % totalScreens;

    // Only apply text updates if the current command is standing idle
    if (currentCommand == "stand") {
      display.clearDisplay();
      display.setTextSize(1);
      display.setTextColor(SSD1306_WHITE);
      display.setCursor(0, 0);

      switch (currentScreenState) {
        case 0:
          // Display current execution mode
          display.println(">> SPECTER-ZERO OS");
          display.println("---------------------");
          display.print("CMD Status: "); display.println(currentCommand);
          display.println("Network: ONLINE [AP]");
          display.display();
          break;

        case 1:
          // Core runtime tracking values
          display.println(">> KINEMATIC DATA");
          display.println("---------------------");
          display.print("Stride Pace: "); display.print(aaDelay); display.println("ms");
          display.print("Frame Sync:  "); display.print(frameDelay); display.println("ms");
          display.println("Gait: Metachronal");
          display.display();
          break;

        case 2:
          // Custom hardware diagnostics screen
          display.println(">> DIAGNOSTICS");
          display.println("---------------------");
          display.println("I2C Bus 0 (PCA): OK");
          display.println("I2C Bus 1 (SSD): OK");
          display.print("Local IP: 192.168.4.1");
          display.display();
          break;

        case 3:
          // Revert back to the classic visual face structure dynamically
          showFaceSleepy();
          break;
      }
    } 
    else if (currentCommand == "sit") {
      showFaceSad();
    }
    else if (currentCommand == "rest") {
      showFaceSleepy();
    }
    else {
      // Keep displaying default face if the robot is active/moving
      showFaceSleepy();
    }
  }
}

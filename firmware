void handleRoot() {
  server.send_P(200, "text/html", HTML_PANEL);
}

void handleControl() {
  if (server.hasArg("cmd")) {
    currentCommand = server.arg("cmd");
  }
  server.send(200, "text/plain", "OK");
}

// ======================================================================
// --- SYSTEM INCEPTION (SETUP) ---
// ======================================================================
void setup() {
  Serial.begin(115200);
  delay(100); // Small stability delay on power-on
  
  // 1. Fire up the Access Point Network and Server Infrastructure first
  IPAddress apIP(192, 168, 4, 1);
  WiFi.softAPConfig(apIP, apIP, IPAddress(255, 255, 255, 0));
  WiFi.softAP(ssid, password);

  dnsServer.start(DNS_PORT, "*", apIP); 

  server.on("/", handleRoot);
  server.on("/control", handleControl);
  server.onNotFound([]() {
    server.send_P(200, "text/html", HTML_PANEL);
  });
  
  server.begin();

  // 2. Initialize Default I2C Port (Pins 21 and 22) for the PCA9685 Driver
  Wire.begin(21, 22); 
  pwm.begin();
  pwm.setOscillatorFrequency(27000000);
  pwm.setPWMFreq(SERVO_FREQ);

  // 3. Initialize the isolated Bus on Pins 15 & 2 AFTER network and core peripherals boot
  I2COLED.begin(15, 18, 400000); 
  
  // 4. Initialize the display 
  if(!display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS, false, false)) { 
    Serial.println("OLED allocation failed");
    // Don't freeze the loop completely if the screen fails—let the web server run!
  } else {
    display.clearDisplay();
    showFaceSleepy();
  }

  delay(200);
  runStandPose(); 
}

// ======================================================================
// --- MAIN EXECUTIVE EXECUTION LOOP ---
// ======================================================================
void loop() {
  dnsServer.processNextRequest(); 
  server.handleClient();          
  
  if (currentCommand == "stand") {
    runStandPose();
  } 
  else if (currentCommand == "sit") {
    runSitPose();
  } 
  else if (currentCommand == "forward") {
    executeForwardStep(); 
  } 
  else if (currentCommand == "right") {
    executeRightTurnStep();
  } 
  else if (currentCommand == "left") {
    executeLeftTurnStep();
  } 
  else if (currentCommand == "hi") {
    executeSayHiStep();
  }
  else if (currentCommand == "rest") {
  executeRest(); 
}
else if (currentCommand == "backward") {
    executeBackwardStep();
  }
}
